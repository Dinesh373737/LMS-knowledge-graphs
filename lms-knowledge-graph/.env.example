# ============================================================
# LMS Knowledge Graph — Environment Variables Template
# Copy this file to .env and fill in your values.
# This file IS committed to git — never put real secrets here.
# ============================================================

# ----------------------------------
# Neo4j (Phase 1 — Local)
# ----------------------------------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ----------------------------------
# FastAPI
# ----------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ----------------------------------
# LLM / Ollama (Phase 1 — Local)
# ----------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ----------------------------------
# Phase 2 placeholders (leave blank for now)
# ----------------------------------
# NEO4J_URI=neo4j+s://<your-auradb-instance>.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# OPENAI_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
